# Required
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Apify fallback for reel downloads
APIFY_API_KEY=apify_api_...

# n8n (self-hosted)
N8N_API_KEY=
N8N_SERVER_URL=https://n8n.yourserver.com

# Telegram bot
TELEGRAM_BOT_TOKEN=

# Whisper settings
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Paths
PLANS_DIR=plans
TEMP_DIR=tmp
